        "metrics": [
          [{"expression": "SEARCH('{Glue,JobName,JobRunId,Type} MetricName=\"glue.ALL.aggregate.recordsRead\"', 'Sum', 300)", "id": "recsRead", "label": "${LABEL}", "visible": true}],
          [{"expression": "SEARCH('{Glue,JobName,JobRunId,Type} MetricName=\"glue.ALL.aggregate.recordsWritten\"', 'Sum', 300)", "id": "recsWritten", "label": "${LABEL}", "visible": true}]
