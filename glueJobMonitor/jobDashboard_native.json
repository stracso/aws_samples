    {
      "type": "text",
      "x": 0,
      "y": 51,
      "width": 24,
      "height": 2,
      "properties": {
        "markdown": "---\n**Note:** This dashboard shows metrics for all Glue jobs that have **Job metrics** enabled. Each time series is auto-labeled with the JobName and JobRunId. The Glue console's summary counters (Total runs, Success rate, DPU hours) and the job runs table require the Glue API and cannot be replicated with native CloudWatch widgets alone — see `jobDashboard_console.json` for the Lambda-backed version."
      }
    }
  ]
}
