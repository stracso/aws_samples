{
  "widgets": [
    {
      "type": "text",
      "x": 0,
      "y": 0,
      "width": 24,
      "height": 2,
      "properties": {
        "markdown": "# Glue Job Monitoring Dashboard (Native CloudWatch)\nThis dashboard uses only native CloudWatch metric widgets — no Lambda required.\nIt relies on Glue job metrics emitted to CloudWatch when **Job metrics** is enabled on your Glue jobs.\n\n---"
      }
    },
    {
      "type": "text",
      "x": 0,
      "y": 2,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "## Job Activity Overview"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 3,
      "width": 8,
      "height": 6,
      "properties": {
        "metrics": [
          [{"expression": "SEARCH('{Glue,JobName,JobRunId,Type} MetricName=\"glue.driver.aggregate.numCompletedStages\"', 'Sum', 300)", "id": "completed", "label": "${LABEL}", "visible": true}]
        ],
        "view": "timeSeries",
        "stacked": false,
        "region": "us-west-2",
        "title": "All Jobs - Completed Stages",
        "period": 300,
        "stat": "Sum",
        "yAxis": {"left": {"min": 0}}
      }
    },
    {
      "type": "metric",
      "x": 8,
      "y": 3,
      "width": 8,
      "height": 6,
      "properties": {
        "metrics": [
          [{"expression": "SEARCH('{Glue,JobName,JobRunId,Type} MetricName=\"glue.driver.aggregate.numFailedStages\"', 'Sum', 300)", "id": "failed", "label": "${LABEL}", "visible": true}]
        ],
        "view": "timeSeries",
        "stacked": false,
        "region": "us-west-2",
        "title": "All Jobs - Failed Stages",
        "period": 300,
        "stat": "Sum",
        "yAxis": {"left": {"min": 0}}
      }
    },
    {
      "type": "metric",
      "x": 16,
      "y": 3,
      "width": 8,
      "height": 6,
      "properties": {
        "metrics": [
          [{"expression": "SEARCH('{Glue,JobName,JobRunId,Type} MetricName=\"glue.driver.aggregate.numCompletedTasks\"', 'Sum', 300)", "id": "completedTasks", "label": "${LABEL}", "visible": true}],
          [{"expression": "SEARCH('{Glue,JobName,JobRunId,Type} MetricName=\"glue.driver.aggregate.numFailedTasks\"', 'Sum', 300)", "id": "failedTasks", "label": "${LABEL}", "visible": true}]
        ],
        "view": "timeSeries",
        "stacked": false,
        "region": "us-west-2",
        "title": "All Jobs - Tasks (Completed / Failed)",
        "period": 300,
        "stat": "Sum",
        "yAxis": {"left": {"min": 0}}
      }
    },
    {
      "type": "text",
      "x": 0,
      "y": 9,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "## Job Duration & Executors"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 10,
      "width": 12,
      "height": 6,
      "properties": {
        "metrics": [
          [{"expression": "SEARCH('{Glue,JobName,JobRunId,Type} MetricName=\"glue.driver.aggregate.elapsedTime\"', 'Maximum', 300)", "id": "elapsed", "label": "${LABEL}", "visible": true}]
        ],
        "view": "timeSeries",
        "stacked": false,
        "region": "us-west-2",
        "title": "All Jobs - Elapsed Time (ms)",
        "period": 300,
        "stat": "Maximum",
        "yAxis": {"left": {"min": 0}}
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 10,
      "width": 12,
      "height": 6,
      "properties": {
        "metrics": [
          [{"expression": "SEARCH('{Glue,JobName,JobRunId,Type} MetricName=\"glue.driver.ExecutorAllocationManager.executors.numberAllExecutors\"', 'Average', 300)", "id": "activeExec", "label": "${LABEL}", "visible": true}],
          [{"expression": "SEARCH('{Glue,JobName,JobRunId,Type} MetricName=\"glue.driver.ExecutorAllocationManager.executors.numberMaxNeededExecutors\"', 'Maximum', 300)", "id": "maxExec", "label": "${LABEL}", "visible": true}]
        ],
        "view": "timeSeries",
        "stacked": false,
        "region": "us-west-2",
        "title": "All Jobs - Active vs Max Needed Executors",
        "period": 300,
        "stat": "Average",
        "yAxis": {"left": {"min": 0}}
      }
    },
    {
      "type": "text",
      "x": 0,
      "y": 16,
      "width": 24,
      "height": 1,
      "properties": {
