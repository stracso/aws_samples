{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListSource",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"        
      ],
      "Resource": "arn:aws:s3:::jpmc-iceberg-warehouse-038676220235-us-west-2"
    },
    {
      "Sid": "ReadSource",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:GetObjectTagging"
      ],
      "Resource": "arn:aws:s3:::jpmc-iceberg-warehouse-038676220235-us-west-2/*"
    },
    {
      "Sid": "WriteDestination",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:PutObjectTagging"
      ],
      "Resource": "arn:aws:s3:::jpmc-iceberg-whv2-038676220235-us-west-2/*"
    },
    {
      "Sid": "ReadManifest",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion"
      ],
      "Resource": "arn:aws:s3:::jpmc-iceberg-whv2-038676220235-us-west-2/migration/*"
    },
    {
      "Sid": "WriteReport",
      "Effect": "Allow",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::jpmc-iceberg-whv2-038676220235-us-west-2/migration/reports/*"
    }
  ]
}